(defn start-server []
  (when @server
    (println "Mematikan server lama...")
    (.stop @server))

  (println "đźš€ Menyalakan server baru di port 8080...")
  (reset! server (jetty/run-jetty app-router {:port 8080 :host "0.0.0.0" :join? false}))
  (println "âś… Server sukses mengudara!"))
