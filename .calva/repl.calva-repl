(ns core
  (:require [ring.adapter.jetty :as jetty]
            [reitit.ring :as ring]))

;; 1. Ini adalah "Controller" kita (mengembalikan Response berupa Map)
(defn handler-ping [_request]
  {:status 200
   :headers {"Content-Type" "application/json"}
   :body "{\"pesan\": \"Alhamdulillah, API Clojure-ku menyala!\", \"status\": \"sukses\"}"})

;; 2. Ini adalah Router kita (didefinisikan menggunakan data Vector)
(def app-router
  (ring/ring-handler
   (ring/router
    ["/api"
     ["/ping" {:get handler-ping}]])))

;; 3. Ini adalah fungsi untuk menghidupkan server Jetty
(defn nyalakan-server []
  (println "đźš€ Server meluncur di port 3000")
  (jetty/run-jetty app-router {:port 3000 :host "0.0.0.0" :join? false}))
